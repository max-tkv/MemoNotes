<Window x:Class="MemoNotes.BoardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="clr-namespace:FontAwesome.WPF;assembly=FontAwesome.WPF"
        mc:Ignorable="d"
        Title="Memo Board" Height="700" Width="1000" MinWidth="400" MinHeight="300"
        WindowStyle="None" AllowsTransparency="True" Background="#1e1e1e"
        Topmost="True" ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen"
        Icon="logo.ico">

    <Window.Resources>
        <!-- Стиль для кнопок тулбара -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3e3e42"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для активной кнопки тулбара (кисть и т.д.) -->
        <Style x:Key="ToolbarButtonActiveStyle" TargetType="Button">
            <Setter Property="Background" Value="#3e3e42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#007ACC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4e4e52"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопки закрытия -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#e81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль текстового блока на доске -->
        <Style x:Key="BoardTextStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#2d2d30"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#3e3e42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="MinHeight" Value="60"/>
        </Style>

        <!-- Стиль для ScaleTransform + ScrollViewer -->
        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border CornerRadius="3"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb Background="#3e3e42" Width="8"
                                           Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Точечная сетка-фон -->
        <DrawingBrush x:Key="DotGridBrush" TileMode="Tile" Viewport="0,0,30,30" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#1e1e1e">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,30,30"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#28FFFFFF">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="15,15" RadiusX="1.5" RadiusY="1.5"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0"
                      CaptionHeight="0"
                      CornerRadius="0"
                      ResizeBorderThickness="5"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <!-- Тулбар -->
        <Border x:Name="ToolbarBorder"
                Background="#252526"
                BorderBrush="#1c1c1c"
                BorderThickness="0,0,0,1"
                Height="40"
                VerticalAlignment="Top"
                Panel.ZIndex="100"
                WindowChrome.IsHitTestVisibleInChrome="True"
                MouseDown="TitleBar_MouseDown">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <!-- Добавить текст -->
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="Добавить текстовый блок (T)"
                            Click="AddTextButton_Click">
                        <fa:ImageAwesome Icon="Font" Width="14" Height="14" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>
                    
                    <!-- Вставить изображение -->
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="Вставить изображение (Ctrl+V)"
                            Click="AddImageButton_Click">
                        <fa:ImageAwesome Icon="Image" Width="14" Height="14" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>

                    <!-- Кисть -->
                    <Button x:Name="BrushButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="Кисть (B)"
                            Click="BrushButton_Click">
                        <fa:ImageAwesome Icon="PaintBrush" Width="14" Height="14" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>

                    <!-- Удалить выбранное -->
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="Удалить выбранное (Delete)"
                            Click="DeleteButton_Click">
                        <fa:ImageAwesome Icon="Trash" Width="14" Height="14" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>
                </StackPanel>

                <!-- Зум индикатор -->
                <TextBlock x:Name="ZoomText"
                           Text="100%"
                           Foreground="#888888"
                           FontSize="12"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                <!-- Кнопки управления окном справа -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0">
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="Настройки"
                            Click="SettingsButton_Click">
                        <fa:ImageAwesome Icon="Gear" Width="14" Height="14" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>

                    <Button x:Name="PinnedButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="Закрепить поверх всех окон"
                            Click="PinnedButton_Click">
                        <fa:ImageAwesome Icon="ThumbTack" Width="14" Height="14" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>

                    <Button x:Name="MaximizeButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="Развернуть во весь экран"
                            Click="MaximizeButton_Click">
                        <fa:ImageAwesome Icon="WindowMaximize" Width="14" Height="14" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>
                    
                    <Button Style="{StaticResource CloseButtonStyle}"
                            ToolTip="Закрыть"
                            Click="CloseButton_Click">
                        <fa:ImageAwesome Icon="Times" Width="14" Height="14" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Область доски -->
        <Border Margin="0,40,0,0"
                Background="#1e1e1e">
            <ScrollViewer x:Name="BoardScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PanningMode="Both"
                          Background="#1e1e1e">
                <ScrollViewer.Template>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="#1e1e1e">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Grid.RowSpan="2"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="2" Grid.Row="0" Grid.RowSpan="2"
                                       Orientation="Vertical"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Style="{StaticResource CustomScrollBar}"/>
                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2"
                                       Orientation="Horizontal"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                       Style="{StaticResource CustomScrollBar}"/>
                            <Rectangle Grid.Column="2" Grid.Row="2" Fill="#1e1e1e"/>
                        </Grid>
                    </ControlTemplate>
                </ScrollViewer.Template>
                <Grid x:Name="BoardContainer"
                      Background="{StaticResource DotGridBrush}">
                    <Grid.LayoutTransform>
                        <ScaleTransform x:Name="BoardScaleTransform" ScaleX="1" ScaleY="1"/>
                    </Grid.LayoutTransform>
                    
                    <Canvas x:Name="BoardCanvas"
                            Background="Transparent"
                            Focusable="True"
                            AllowDrop="True"
                            DragEnter="BoardCanvas_DragEnter"
                            DragOver="BoardCanvas_DragOver"
                            Drop="BoardCanvas_Drop"
                            MouseWheel="BoardCanvas_MouseWheel"
                            MouseDown="BoardCanvas_MouseDown"
                            MouseRightButtonUp="BoardCanvas_MouseRightButtonUp">
                        <!-- Сетка-фон (точки) -->
                    </Canvas>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
