<Window x:Class="MemoNotes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:enums="clr-namespace:MemoNotes.Enums"
        xmlns:fa="clr-namespace:FontAwesome.WPF;assembly=FontAwesome.WPF"
        mc:Ignorable="d"
        Title="Настройки" Height="600" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        WindowStartupLocation="CenterScreen"
        Icon="logo.ico">

    <Window.Resources>
        <!-- Стиль для ComboBox -->
        <Style x:Key="CustomComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#3e3e42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1c1c1c"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="PART_ToggleButton"
                                          Background="#3e3e42"
                                          BorderBrush="#1c1c1c"
                                          BorderThickness="1"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <ContentPresenter Margin="8,4,24,4"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"/>
                                                <Path Name="Arrow"
                                                      Data="M0,0 L6,0 L3,5 Z"
                                                      Fill="White"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"
                                                      Opacity="0.6"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Arrow" Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="PART_ContentSite"
                                              Margin="8,4,24,4"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>
                            <TextBox Name="PART_EditableTextBox"
                                     Visibility="Hidden"
                                     Background="Transparent"
                                     Foreground="White"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     Focusable="False"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Left"
                                     Margin="8,4,24,4"/>
                            <Popup Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Slide">
                                <Border Background="#2d2d30"
                                        BorderBrush="#1c1c1c"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,2,0,0">
                                    <ScrollViewer Margin="4"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для ComboBoxItem -->
        <Style x:Key="CustomComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3"
                                Margin="2">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3e3e42"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#094771"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumb"
               TargetType="{x:Type Thumb}">
            <Setter Property="SnapsToDevicePixels"
                    Value="True" />
            <Setter Property="OverridesDefaultStyle"
                    Value="true" />
            <Setter Property="IsTabStop"
                    Value="false" />
            <Setter Property="Focusable"
                    Value="false" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border CornerRadius="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для пользовательской полосы прокрутки -->
        <Style x:Key="CustomScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb Background="#3e3e42"
                                           Width="8"
                                           Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0"
                      CaptionHeight="0"
                      CornerRadius="0"
                      ResizeBorderThickness="5"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Border x:Name="MainBorder"
                Background="#262626"
                BorderBrush="#1c1c1c"
                BorderThickness="1"
                MouseDown="TitleBar_MouseDown">
            <Grid>
                <!-- Кнопка закрытия -->
                <Button Height="20"
                        Width="20"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Right"
                        Margin="0,3,5,0"
                        ClickMode="Release"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Foreground="White"
                        IsEnabled="True"
                        Click="CloseButton_Click">
                    <fa:ImageAwesome Icon="Times" Width="12" Height="12" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    Padding="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#e81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Заголовок -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Left"
                            Margin="12,6,0,0">
                    <fa:ImageAwesome Icon="Gear"
                                     Foreground="White"
                                     Width="14"
                                     Height="14"
                                     VerticalAlignment="Center"
                                     Margin="0,0,4,0"/>
                    <TextBlock Text="Настройки"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Разделительная линия -->
                <Border VerticalAlignment="Top"
                        Height="1"
                        Background="#3e3e42"
                        Margin="0,28,0,0"/>

                <!-- Содержимое настроек -->
                <Grid Margin="20,40,20,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок: Угол активации -->
                        <TextBlock
                            Grid.Row="0"
                            Text="Угол активации:"
                            FontSize="14"
                            Foreground="#cccccc"
                            VerticalAlignment="Center"
                            Margin="0,0,0,10"/>

                        <ComboBox
                            Grid.Row="1"
                            x:Name="CornerComboBox"
                            Style="{StaticResource CustomComboBoxStyle}"
                            ItemContainerStyle="{StaticResource CustomComboBoxItemStyle}"
                            Height="32"
                            SelectedIndex="0">
                            <ComboBoxItem Content="Верхний левый" Tag="{x:Static enums:MousePosition.UpperLeft}"/>
                            <ComboBoxItem Content="Верхний правый" Tag="{x:Static enums:MousePosition.UpperRight}"/>
                            <ComboBoxItem Content="Нижний левый" Tag="{x:Static enums:MousePosition.BottomLeft}"/>
                            <ComboBoxItem Content="Нижний правый" Tag="{x:Static enums:MousePosition.BottomRight}"/>
                        </ComboBox>

                        <!-- Разделитель -->
                        <Border Grid.Row="2" Height="1" Background="#3e3e42" Margin="0,15,0,15"/>

                        <!-- Клавиша непрерывного рисования -->
                        <TextBlock
                            Grid.Row="3"
                            Text="Клавиша непрерывного рисования:"
                            FontSize="14"
                            Foreground="#cccccc"
                            VerticalAlignment="Center"
                            Margin="0,0,0,4"
                            TextWrapping="Wrap"/>
                        <TextBlock
                            Grid.Row="4"
                            Text="Зажатая клавиша = один элемент"
                            FontSize="11"
                            Foreground="#888888"
                            VerticalAlignment="Center"
                            Margin="0,0,0,4"/>

                        <Grid Grid.Row="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox
                                x:Name="ContinuousStrokeKeyTextBox"
                                Height="32"
                                IsReadOnly="True"
                                Text="Нет"
                                Foreground="#cccccc"
                                FontSize="14"
                                VerticalContentAlignment="Center"
                                Padding="8,0"
                                Background="#3e3e42"
                                BorderBrush="#1c1c1c"
                                BorderThickness="1"
                                CaretBrush="White"
                                ToolTip="Нажмите на поле, затем зажмите модификаторы и клавишу"
                                PreviewMouseLeftButtonDown="ContinuousStrokeKeyTextBox_MouseDown"
                                LostFocus="ContinuousStrokeKeyTextBox_LostFocus"/>
                            <Button
                                Grid.Column="1"
                                Content="Сброс"
                                Height="32"
                                Width="60"
                                Margin="5,0,0,0"
                                Background="#3e3e42"
                                Foreground="#cccccc"
                                BorderBrush="#1c1c1c"
                                BorderThickness="1"
                                FontSize="13"
                                Click="ResetContinuousStrokeKey_Click"/>
                        </Grid>

                        <!-- Разделитель -->
                        <Border Grid.Row="6" Height="1" Background="#3e3e42" Margin="0,15,0,15"/>

                        <!-- Заголовок секции: Облако -->
                        <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,0,0,10">
                            <fa:ImageAwesome Icon="CloudUpload"
                                             Foreground="#4a9eff"
                                             Width="16"
                                             Height="16"
                                             VerticalAlignment="Center"
                                             Margin="0,0,6,0"/>
                            <TextBlock Text="Облачная синхронизация"
                                       FontSize="14"
                                       Foreground="#4a9eff"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Выбор провайдера -->
                        <TextBlock
                            Grid.Row="8"
                            Text="Провайдер:"
                            FontSize="13"
                            Foreground="#cccccc"
                            VerticalAlignment="Center"
                            Margin="0,0,0,6"/>

                        <ComboBox
                            Grid.Row="9"
                            x:Name="CloudProviderComboBox"
                            Style="{StaticResource CustomComboBoxStyle}"
                            ItemContainerStyle="{StaticResource CustomComboBoxItemStyle}"
                            Height="32"
                            SelectedIndex="0">
                            <ComboBoxItem Content="Отключено" Tag="0"/>
                            <ComboBoxItem Content="Яндекс Диск" Tag="1"/>
                        </ComboBox>

                        <!-- Подсказка -->
                        <TextBlock
                            Grid.Row="10"
                            x:Name="CloudHintText"
                            Text="Данные автоматически сохраняются на Яндекс Диск при каждом изменении доски"
                            FontSize="11"
                            Foreground="#888888"
                            VerticalAlignment="Center"
                            Margin="0,6,0,6"
                            TextWrapping="Wrap"
                            Visibility="Collapsed"/>

                        <!-- Кнопки авторизации -->
                        <Grid Grid.Row="11" x:Name="CloudAuthPanel" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button
                                x:Name="CloudAuthButton"
                                Grid.Column="0"
                                Content="🔗  Авторизоваться через Яндекс"
                                Height="32"
                                Background="#4a9eff"
                                Foreground="White"
                                BorderBrush="#3a8eef"
                                BorderThickness="1"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Click="CloudAuthButton_Click"
                                ToolTip="Открыть браузер для авторизации на Яндекс Диске"
                                Cursor="Hand"/>

                            <Button
                                Grid.Column="1"
                                x:Name="CloudLogoutButton"
                                Height="32"
                                Width="75"
                                Margin="5,0,0,0"
                                Background="#3e3e42"
                                Foreground="#cccccc"
                                BorderBrush="#1c1c1c"
                                BorderThickness="1"
                                FontSize="12"
                                Content="Выйти"
                                Click="CloudLogoutButton_Click"
                                Visibility="Collapsed"
                                ToolTip="Выйти из учётной записи Яндекс"/>
                            
                        </Grid>

                        <!-- Статус подключения -->
                        <StackPanel
                            Grid.Row="12"
                            x:Name="CloudStatusPanel"
                            Orientation="Horizontal"
                            Margin="0,8,0,0"
                            Visibility="Collapsed">
                            <Ellipse x:Name="CloudStatusDot"
                                     Width="10"
                                     Height="10"
                                     Fill="#555555"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0"/>
                            <TextBlock x:Name="CloudStatusText"
                                       Text="Не подключено"
                                       FontSize="12"
                                       Foreground="#888888"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                    </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
